# KYC/AML Agentic AI System - Environment Configuration

# Frontend Configuration
FRONTEND_PORT=3000
FRONTEND_DEBUG=false
FRONTEND_API_URL=http://localhost:8000

# API Gateway Configuration
API_GATEWAY_PORT=8000
API_GATEWAY_DEBUG=false
ORCHESTRATION_SERVICE_URL=http://localhost:8010
API_REQUEST_TIMEOUT=300

# Orchestration Service Configuration
ORCHESTRATION_PORT=8010
ORCHESTRATION_DEBUG=false
ORCHESTRATION_TIMEOUT=300

# Extract Agent Configuration
EXTRACT_AGENT_PORT=8001
EXTRACT_AGENT_TIMEOUT=120
EXTRACT_AGENT_DEBUG=false

# Verify Agent Configuration
VERIFY_AGENT_PORT=8002
VERIFY_AGENT_TIMEOUT=60
VERIFY_AGENT_DEBUG=false

# Reason Agent Configuration (LLM)
REASON_AGENT_PORT=8003
REASON_AGENT_TIMEOUT=120
REASON_AGENT_DEBUG=false
OLLAMA_URL=http://localhost:11434
LLM_MODEL=mistral

# Risk Agent Configuration
RISK_AGENT_PORT=8004
RISK_AGENT_TIMEOUT=60
RISK_AGENT_DEBUG=false

# Decision Agent Configuration
DECISION_AGENT_PORT=8005
DECISION_AGENT_TIMEOUT=60
DECISION_AGENT_DEBUG=false

# Ollama LLM Service Configuration
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODELS=mistral,neural-chat,llama2

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security Configuration
ENABLE_CORS=true
CORS_ORIGINS=*
ENABLE_AUTH=false
JWT_SECRET=your-secret-key-here

# Performance Configuration
MAX_WORKERS=4
MAX_REQUEST_SIZE=50
CACHE_ENABLED=true
CACHE_TTL=300

# Database Configuration (if needed)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kyc_system
DB_USER=kyc_user
DB_PASSWORD=secure_password

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=

# File Upload Configuration
MAX_FILE_SIZE=50000000
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,gif,bmp
UPLOAD_TEMP_DIR=/tmp/kyc-uploads

# Production Settings
ENVIRONMENT=development
DEBUG=false
SECURE_SSL=false
ALLOWED_HOSTS=localhost,127.0.0.1

